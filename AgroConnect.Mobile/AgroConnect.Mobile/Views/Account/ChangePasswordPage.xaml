<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:AgroConnect.Mobile.ViewModels.Account"
             xmlns:conv="clr-namespace:AgroConnect.Mobile.Converters"
             x:Class="AgroConnect.Mobile.Views.Account.ChangePasswordPage"
             x:DataType="vm:ChangePasswordViewModel"
             Title="Cambiar contraseña" BackgroundColor="{StaticResource Background}">
    <ContentPage.Resources>
        <conv:InvertBoolConverter x:Key="InvertBool" />
        <conv:StringNotNullOrEmptyConverter x:Key="StringNotEmpty" />
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Spacing="16" Padding="24" VerticalOptions="Center">

            <Label Text="🔒" FontSize="48" HorizontalOptions="Center" />
            <Label Text="Cambiar contraseña" FontSize="20" FontAttributes="Bold"
                   TextColor="{StaticResource TextPrimary}" HorizontalOptions="Center" />
            <Label Text="Ingresá tu contraseña actual y elegí una nueva."
                   FontSize="13" TextColor="{StaticResource TextSecondary}"
                   HorizontalOptions="Center" HorizontalTextAlignment="Center" Margin="0,0,0,10" />

            <!-- Contraseña actual -->
            <VerticalStackLayout Spacing="4">
                <Label Text="Contraseña actual" FontSize="13" TextColor="{StaticResource TextSecondary}" />
                <Entry Text="{Binding CurrentPassword}" Placeholder="••••••"
                       Style="{StaticResource FormEntry}" IsPassword="True" ReturnType="Next" />
            </VerticalStackLayout>

            <!-- Nueva contraseña -->
            <VerticalStackLayout Spacing="4">
                <Label Text="Nueva contraseña (mín. 6 caracteres)" FontSize="13" TextColor="{StaticResource TextSecondary}" />
                <Entry Text="{Binding NewPassword}" Placeholder="••••••"
                       Style="{StaticResource FormEntry}" IsPassword="True" ReturnType="Next" />
            </VerticalStackLayout>

            <!-- Confirmar nueva -->
            <VerticalStackLayout Spacing="4">
                <Label Text="Confirmar nueva contraseña" FontSize="13" TextColor="{StaticResource TextSecondary}" />
                <Entry Text="{Binding ConfirmPassword}" Placeholder="••••••"
                       Style="{StaticResource FormEntry}" IsPassword="True" ReturnType="Done" />
            </VerticalStackLayout>

            <!-- Error -->
            <Label Text="{Binding ErrorMessage}" TextColor="{StaticResource Error}"
                   IsVisible="{Binding ErrorMessage, Converter={StaticResource StringNotEmpty}}"
                   HorizontalOptions="Center" FontSize="14" />

            <!-- Botón -->
            <Button Text="Cambiar contraseña" Command="{Binding ChangePasswordCommand}"
                    Style="{StaticResource PrimaryButton}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBool}}" />

            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" HorizontalOptions="Center" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
