<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:AgroConnect.Mobile.ViewModels.Recipes"
             x:Class="AgroConnect.Mobile.Views.Recipes.RecipeDetailPage"
             x:DataType="vm:RecipeDetailViewModel"
             Title="Detalle Receta" BackgroundColor="{StaticResource Background}">
    <VerticalStackLayout Padding="16">
        <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" />
        <Label Text="{Binding Recipe.PublicCode}" Style="{StaticResource TitleLabel}" />
    </VerticalStackLayout>
</ContentPage>
