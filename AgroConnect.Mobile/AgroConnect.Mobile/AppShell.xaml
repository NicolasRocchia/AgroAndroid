<?xml version="1.0" encoding="UTF-8" ?>
<Shell xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
       xmlns:homeViews="clr-namespace:AgroConnect.Mobile.Views.Home"
       xmlns:jobViews="clr-namespace:AgroConnect.Mobile.Views.Jobs"
       xmlns:execViews="clr-namespace:AgroConnect.Mobile.Views.Execution"
       xmlns:profileViews="clr-namespace:AgroConnect.Mobile.Views.Profile"
       xmlns:accountViews="clr-namespace:AgroConnect.Mobile.Views.Account"
       x:Class="AgroConnect.Mobile.AppShell"
       Shell.FlyoutBehavior="Disabled">

    <!-- Login (ruta global //login, sin tabs) -->
    <ShellContent Route="login"
                  ContentTemplate="{DataTemplate accountViews:LoginPage}"
                  Shell.TabBarIsVisible="False"
                  Shell.NavBarIsVisible="False" />

    <!-- ═══ Tabs Aplicador (4 tabs) ═══ -->
    <TabBar x:Name="ApplicatorTabs" Route="main">

        <ShellContent Title="Inicio"
                      Icon="icon_home.png"
                      ContentTemplate="{DataTemplate homeViews:HomePage}"
                      Route="home" />

        <ShellContent Title="Trabajos"
                      Icon="icon_jobs.png"
                      ContentTemplate="{DataTemplate jobViews:JobListPage}"
                      Route="jobs" />

        <ShellContent Title="Ejecuciones"
                      Icon="icon_exec.png"
                      ContentTemplate="{DataTemplate execViews:ExecutionListPage}"
                      Route="executions" />

        <ShellContent Title="Perfil"
                      Icon="icon_profile.png"
                      ContentTemplate="{DataTemplate profileViews:ProfilePage}"
                      Route="profile" />

    </TabBar>

    <!-- ═══ Tabs Operario (2 tabs) ═══ -->
    <TabBar x:Name="OperatorTabs" Route="operator">

        <ShellContent Title="Inicio"
                      Icon="icon_home.png"
                      ContentTemplate="{DataTemplate homeViews:HomePage}"
                      Route="home" />

        <ShellContent Title="Ejecuciones"
                      Icon="icon_exec.png"
                      ContentTemplate="{DataTemplate execViews:ExecutionListPage}"
                      Route="executions" />

    </TabBar>

</Shell>
